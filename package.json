{
  "name": "larminay-vault",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm i && node start.js --dev",
    "build": "nuxt build --dotenv .env.production",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "docker": "docker-compose -f docker-compose.yml up -d",
    "db:studio": "prisma studio --browser none",
    "db:reset": "prisma migrate reset --skip-seed -f",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma migrate reset -f",
    "db:migrate": "prisma migrate dev --name",
    "test": "playwright test",
    "s3-monitor": "node --loader ts-node/esm tools/s3Monitor.ts"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seeds/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.1",
    "@aws-sdk/lib-storage": "^3.620.1",
    "@meforma/vue-toaster": "^1.3.0",
    "@pinia/nuxt": "^0.5.2",
    "@prisma/client": "^5.17.0",
    "@quasar/extras": "^1.16.12",
    "@tailwindcss/container-queries": "^0.1.1",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "chart.js": "^4.4.3",
    "glightbox": "^3.3.0",
    "image-size": "^1.1.1",
    "lightgallery": "^2.7.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "pinia": "^2.2.0",
    "pm2": "^5.4.2",
    "quasar": "^2.16.6",
    "shelljs": "^0.8.5",
    "trpc-nuxt": "^0.10.22",
    "validator": "^13.12.0",
    "vue-chartjs": "^5.3.1",
    "vue-markdown-render": "^2.2.1",
    "vuewordcloud": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@nuxt/devtools": "latest",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@playwright/test": "^1.45.3",
    "@sidebase/nuxt-auth": "^0.6.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/shelljs": "^0.8.15",
    "@types/validator": "^13.12.0",
    "@vite-pwa/nuxt": "^0.9.1",
    "concurrently": "^8.2.2",
    "dayjs-nuxt": "^2.1.9",
    "next-auth": "4.22.5",
    "npm-check-updates": "^16.14.20",
    "nuxt": "^3.12.4",
    "nuxt-quasar-ui": "^2.1.3",
    "prettier": "^3.3.3",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vue": "^3.4.34",
    "vue-router": "^4.4.0",
    "vue-tsc": "^2.0.29"
  }
}
